# Variáveis de ambiente para o pipeline de fine-tuning

# ─── API WordPress ────────────────────────────────────────────────────────────
WP_BASE_URL=https://example.com/wp-json/wp/v2
WP_USERNAME=
WP_APP_PASSWORD=
MAX_POSTS=0

# ─── Modelo ───────────────────────────────────────────────────────────────────
# ID HuggingFace para treino e conversão LoRA → GGUF (apenas config é baixado na exportação)
MODEL_HF_ID=Qwen/Qwen3.5-2B

# Repositório HuggingFace do GGUF base (para make download-base)
MODEL_REPO_ID=unsloth/Qwen3.5-2B-GGUF

# Nome do arquivo GGUF local (inferência via llama-cli)
MODEL_FILENAME=Qwen3.5-2B-Q4_K_M.gguf

# ─── Treinamento ─────────────────────────────────────────────────────────────
TRAIN_ITERS=1000
CPU_THREADS=6

# ─── Publicação no Hugging Face Hub (make push) ──────────────────────────────
# Token com permissão de escrita: https://huggingface.co/settings/tokens
HF_TOKEN=
# Repositório de destino do modelo fundido (ex: seu-usuario/nome-do-modelo)
HF_PUSH_REPO=

# ─── Ollama (make ollama-create / make push-ollama) ──────────────────────────
# Opcional — se vazio, as etapas ollama são puladas automaticamente
# Formato: usuario/nome-do-modelo (ex: usuario/nome-do-modelo)
# Requer ollama instalado: https://ollama.com/download
OLLAMA_MODEL=
# API key para push em repositório público: https://ollama.com/settings/api-keys
OLLAMA_API_KEY=

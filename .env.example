# Variáveis de ambiente para o pipeline de fine-tuning

# ─── API WordPress ────────────────────────────────────────────────────────────
WP_BASE_URL=https://example.com/wp-json/wp/v2
WP_USERNAME=
WP_APP_PASSWORD=
MAX_POSTS=0

# ─── Modelo ───────────────────────────────────────────────────────────────────
# ID HuggingFace para treino e conversão LoRA → GGUF (apenas config é baixado na exportação)
MODEL_HF_ID=Qwen/Qwen3.5-9B

# Repositório HuggingFace do GGUF base (para make download-base)
MODEL_REPO_ID=unsloth/Qwen3.5-9B-GGUF

# Nome do arquivo GGUF local (inferência via llama-cli)
MODEL_FILENAME=Qwen3.5-9B-Q4_K_M.gguf

# ─── Treinamento ─────────────────────────────────────────────────────────────
TRAIN_ITERS=500
CPU_THREADS=6

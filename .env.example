# Variáveis de ambiente para o pipeline de fine-tuning

# ─── API WordPress ────────────────────────────────────────────────────────────
WP_BASE_URL=https://example.com/wp-json/wp/v2
WP_USERNAME=
WP_APP_PASSWORD=
MAX_POSTS=0

# ─── Modelo ───────────────────────────────────────────────────────────────────
# ID HuggingFace para treino e conversão LoRA → GGUF (apenas config é baixado na exportação)
MODEL_HF_ID=Qwen/Qwen3.5-0.8B

# Repositório HuggingFace do GGUF base (para make download-base)
MODEL_REPO_ID=unsloth/Qwen3.5-0.8B-GGUF

# Nome do arquivo GGUF local (inferência via llama-cli)
MODEL_FILENAME=Qwen3.5-0.8B-Q4_K_M.gguf

# ─── Treinamento ─────────────────────────────────────────────────────────────
# Épocas alvo — steps são calculados automaticamente (dataset_size / batch_efetivo * epochs)
TRAIN_EPOCHS=20
# Hard cap de steps (0 = sem limite, respeita só TRAIN_EPOCHS)
TRAIN_ITERS=1000
# Limite de chars do conteúdo por entrada (~714 tokens). Garante que o token de fim
# nunca seja truncado pelo max_length=1280 do trainer (overhead fixo: ~269 tokens)
MAX_CONTENT_CHARS=2500
CPU_THREADS=6

# ─── Publicação no Hugging Face Hub (make push) ──────────────────────────────
# Token com permissão de escrita: https://huggingface.co/settings/tokens
HF_TOKEN=
# Repositório de destino do modelo fundido (ex: seu-usuario/nome-do-modelo)
HF_PUSH_REPO=
